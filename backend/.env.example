# Server
APP_NAME=Smart Email Agent API
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Feature flags
# Keep both false for real Google OAuth/Gmail behavior.
ENABLE_MOCK_MODE=false
ENABLE_DEV_ENDPOINTS=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Session (use a long random string in production)
SESSION_SECRET_KEY=change-me-in-production-use-a-long-random-string

# PostgreSQL — use DATABASE_URL or individual variables
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/email_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=email_agent

# Google OAuth / Gmail API
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Optional: path to OAuth client JSON from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# Gmail sync
GMAIL_SYNC_MAX_RESULTS=50

# Ollama / Phi-3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=512
OLLAMA_JSON_PARSE_RETRIES=3

# Follow-up detection (hours)
FOLLOWUP_STALE_HOURS=48
FOLLOWUP_PRIORITY_STALE_HOURS=24

